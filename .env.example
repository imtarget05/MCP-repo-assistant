# GitHub & LLM API Keys
GITHUB_TOKEN=your_github_token_here
OPENAI_API_KEY=your_openai_api_key_here
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# API Security & CORS
# Set API_SECRET_KEY to require 'X-API-Key' authentication on all RAG/Chat/Orchestrator endpoints
API_SECRET_KEY=your_production_secret_api_key_here
ALLOWED_ORIGINS=http://localhost:8000,http://127.0.0.1:8000

# Rate Limiting & Timeouts
RATE_LIMIT_MAX=30
REQUEST_TIMEOUT_SECONDS=120

# Qdrant Vector Store
# QDRANT_URL=http://localhost:6333 # Local standalone/Docker URL
# QDRANT_API_KEY=your_qdrant_api_key_here

# Structured Logging
LOG_LEVEL=INFO

# Monitoring & Tracing (Optional)
LANGFUSE_PUBLIC_KEY=your_langfuse_public_key_here
LANGFUSE_SECRET_KEY=your_langfuse_secret_key_here
LANGFUSE_HOST=https://cloud.langfuse.com
